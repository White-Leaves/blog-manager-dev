<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.pcb4.mapper.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.example.pcb4.entity.SysUser">
            <id property="id" column="id" />
            <result property="mobile" column="mobile" />
            <result property="name" column="name" />
            <result property="password" column="password" />
            <result property="isDelete" column="is_delete" />
    </resultMap>

    <sql id="Base_Column_List">
        id,mobile,name,password,is_delete
    </sql>
    <select id="selectByName" resultType="com.example.pcb4.entity.SysUser">
        select * from `sys_user` where `name` = #{name}
    </select>

    <update id="UpdateUserInfo">
        update sys_user u
        set u.name = #{name},u.mobile = #{mobile}
        where id = #{id};
    </update>

    <update id="ResetPwd">
        update sys_user u
        set password = #{newPwd}
        where id = #{id};
    </update>
</mapper>
