<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.pcb4.mapper.SysRoleMapper">

    <resultMap id="BaseResultMap" type="com.example.pcb4.entity.SysRole">
            <id property="id" column="id" />
            <result property="code" column="code" />
            <result property="name" column="name" />
            <result property="isDelete" column="is_delete" />
    </resultMap>

    <sql id="Base_Column_List">
        id,code,name,is_delete
    </sql>
    <select id="selectMenusByRoleId" resultType="com.example.pcb4.entity.SysMenu"
            parameterType="java.lang.Long">
        select m.* from sys_menu m
        left join sys_role_menu rm on m.id = rm.menu_id
        left join sys_role r on r.id = rm.role_id
        where r.id = #{id}
    </select>
</mapper>
